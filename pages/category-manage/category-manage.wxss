/* pages/category-manage/category-manage.wxss */
page { background: #FAFAF7; }
.page { min-height: 100vh; padding-bottom: 40rpx; }

.page-header {
  padding: 48rpx 36rpx 32rpx;
  border-bottom: 1rpx solid #F0EDE6;
  background: #fff;
  margin-bottom: 24rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #1A1A18;
  margin-bottom: 8rpx;
}

.page-sub {
  display: block;
  font-size: 26rpx;
  color: #9E9E8A;
}

.cat-list {
  padding: 0 24rpx;
}

.cat-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  gap: 16rpx;
}

.cat-left {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 20rpx;
  overflow: hidden;
}

.cat-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cat-icon { font-size: 36rpx; }

.cat-info { overflow: hidden; }

.cat-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A18;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cat-meta {
  display: block;
  font-size: 24rpx;
  color: #9E9E8A;
}

.cat-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.act-btn {
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  border: 1rpx solid #E0DDD5;
  background: #fff;
  font-size: 24rpx;
  color: #6A6A5A;
}

.act-btn.danger {
  border-color: #F0D8D8;
  color: #E05050;
}

.add-cat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin: 24rpx;
  padding: 28rpx;
  background: #fff;
  border: 2rpx dashed #C8C4B8;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #3D7A5C;
  font-weight: 600;
}

.add-icon {
  font-size: 40rpx;
  font-weight: 300;
  color: #3D7A5C;
}
