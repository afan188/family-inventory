/* pages/category/category.wxss */
page { background: #FAFAF7; }
.page { min-height: 100vh; padding-bottom: 40rpx; }

.cat-header {
  display: flex;
  align-items: center;
  padding: 48rpx 36rpx;
  gap: 24rpx;
}

.cat-icon { font-size: 80rpx; flex-shrink: 0; }

.cat-title-wrap { flex: 1; }

.cat-name { display: block; font-size: 40rpx; font-weight: 800; color: #1A1A18; margin-bottom: 8rpx; }

.cat-count { display: block; font-size: 26rpx; color: #7A7A6A; }

.cat-add {
  width: 72rpx; height: 72rpx;
  background: #fff;
  border: 1rpx solid #E0DDD5;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; color: #3D7A5C; font-weight: 300;
}

.list { padding: 0 24rpx; }

.list-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.item-icon {
  width: 80rpx; height: 80rpx;
  border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.item-body { flex: 1; overflow: hidden; }

.item-name { display: block; font-size: 30rpx; font-weight: 600; color: #1A1A18; margin-bottom: 6rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.item-specs { font-size: 24rpx; color: #9E9E8A; margin-bottom: 8rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.item-footer { display: flex; justify-content: space-between; align-items: center; }

.item-price { font-size: 28rpx; font-weight: 700; color: #C88A2C; }

.item-date { font-size: 22rpx; color: #9E9E8A; }

.item-arrow { font-size: 32rpx; color: #C8C4B8; margin-left: 12rpx; flex-shrink: 0; }

.empty { text-align: center; padding: 120rpx 40rpx; }

.empty-icon { display: block; font-size: 100rpx; margin-bottom: 24rpx; }

.empty-t { display: block; font-size: 30rpx; color: #9E9E8A; margin-bottom: 32rpx; }

.empty-add {
  display: inline-block;
  background: #3D7A5C;
  color: #fff;
  padding: 20rpx 48rpx;
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 600;
}
