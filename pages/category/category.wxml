<!-- pages/category/category.wxml -->
<view class="page">
  <!-- 分类标题 -->
  <view class="cat-header" style="background:{{catColor}}18">
    <text class="cat-icon">{{catIcon}}</text>
    <view class="cat-title-wrap">
      <text class="cat-name">{{catName}}</text>
      <text class="cat-count">{{items.length}} 件物品 · 合计 ¥{{totalValue_str}}</text>
    </view>
    <view class="cat-add" bindtap="goAdd">
      <text>+</text>
    </view>
  </view>

  <!-- 物品列表 -->
  <view wx:if="{{items.length > 0}}" class="list">
    <view 
      wx:for="{{items}}" 
      wx:key="id"
      class="list-item"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <view class="item-icon" style="background:{{catColor}}18">
        <text>{{catIcon}}</text>
      </view>
      <view class="item-body">
        <text class="item-name">{{item.name}}</text>
        <view class="item-specs">
          <text wx:if="{{item.specs.brand}}">{{item.specs.brand}}</text>
          <text wx:if="{{item.specs.model}}"> · {{item.specs.model}}</text>
          <text wx:if="{{item.specs.color}}"> · {{item.specs.color}}</text>
        </view>
        <view class="item-footer">
          <text class="item-price">¥{{item.price_str}}</text>
          <text class="item-date">{{item.date_str}}</text>
        </view>
      </view>
      <text class="item-arrow">›</text>
    </view>
  </view>

  <view wx:else class="empty">
    <text class="empty-icon">{{catIcon}}</text>
    <text class="empty-t">该分类暂无物品</text>
    <view class="empty-add" bindtap="goAdd">
      <text>添加第一件物品</text>
    </view>
  </view>
</view>
